# Copie este arquivo para `.env` e preencha com a chave real do time:
#   cp .env.example .env
#
# A mesma chave precisa estar embutida no bookmarklet "PARAR e Exportar"
# (campo TEAM_KEY) para que as sessoes exportadas possam ser abertas no analisador.
# Guarde a chave no cofre de senhas do time. Nunca faca commit do arquivo `.env`.
TEAM_KEY=sua-chave-secreta-do-time-aqui
